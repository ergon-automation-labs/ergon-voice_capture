# Voice Capture Bot environment configuration
# Copy to .env and customize

# NATS connection
NATS_HOST=localhost
NATS_PORT=4223

# Whisper model (mlx-community/whisper-medium.en-mlx recommended for Apple Silicon)
WHISPER_MODEL=medium.en

# HTTP endpoint for G2 companion app
BOT_ARMY_VOICE_CAPTURE_HTTP_ENABLED=true
BOT_ARMY_VOICE_CAPTURE_HTTP_PORT=39901
BOT_ARMY_VOICE_CAPTURE_HTTP_TOKEN=

# Enable Python Whisper for integration tests
# VOICE_CAPTURE_ENABLE_WHISPER=1